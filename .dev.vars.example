# Kopiere diese Datei nach .dev.vars und füge deine Werte ein.
# .dev.vars wird von Wrangler geladen (nicht ins Repo committen).

# Mind. 32 Zeichen – für JWT-Signatur der Auth-Session
JWT_SECRET=dein-mindestens-32-zeichen-langer-geheimer-schluessel

# --- Web Push (VAPID) – ein Schlüsselpaar für die gesamte PWA, nicht pro User ---
# Schlüssel erzeugen: npx @pushforge/builder vapid
# Danach pnpm dev neu starten. Migration: migrations/0031_push_subscriptions.sql (lokal + remote).
# Push testen: Profil → Push-Benachrichtigungen aktivieren → Browser-Erlaubnis
# Lokal nutzt die App dafür public/push-sw.js (Serwist-SW ist in dev absichtlich deaktiviert).
# Migration: 0031_push_subscriptions.sql + 0032_user_push_preferences.sql + 0033_user_reise_gps_mode.sql
# Produktion: npx wrangler secret put VAPID_PUBLIC_KEY (usw.), niemals committen
VAPID_PUBLIC_KEY=dein-oeffentlicher-vapid-schluessel
# Private Key als JSON – in einfache Anführungszeichen, sonst kann Wrangler den Wert falsch parsen:
VAPID_PRIVATE_KEY='{"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}'
VAPID_SUBJECT=mailto:deine@email.de

# --- Optional: Camping-Foto-Nachkomprimierung (Admin /datensicherung) ---
# Free Tier: Standard 1 Foto je Request (Workers CPU + Subrequests). Auf Paid höher möglich.
# REOPTIMIZE_BATCH_SIZE=1
# Leichtere WebP-Parameter nur für Bulk-Nachlauf (Uploads bleiben 1600 px @ 85 %):
# REOPTIMIZE_MAX_EDGE=896
# REOPTIMIZE_WEBP_QUALITY=72
# Sehr große JPG/PNG vor der Dekodierung überspringen (Workers Free CPU, Standard ~5 MP):
# REOPTIMIZE_MAX_DECODE_MEGAPIXELS=5

# --- Optional: Admin-Backup mit R2-Bildern (ZIP-Teile) ---
# Workers Free: nur begrenzte Subrequests pro Aufruf; pro ZIP-Teil werden nur wenige R2-Objekte gelesen (Default 28).
# EXPORT_R2_BATCH_LIMIT=20
